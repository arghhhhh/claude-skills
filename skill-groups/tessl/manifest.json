{
  "name": "tessl",
  "description": "Tessl CLI — package manager for agent skills. Search, install, publish, and evaluate skills from the Tessl registry.",
  "version": "0.1.0",
  "prerequisites": [],
  "install": {
    "check": "tessl --version",
    "methods": [
      {
        "name": "install-script",
        "platforms": ["macos", "linux"],
        "check": "curl --version",
        "command": "curl -fsSL https://get.tessl.io | sh"
      },
      {
        "name": "manual",
        "platforms": ["macos", "linux", "windows"],
        "url": "https://tessl.io/"
      }
    ]
  },
  "test": {
    "command": "tessl --version",
    "expect_success": true
  },
  "skills": [
    "tessl"
  ],
  "agents": []
}
